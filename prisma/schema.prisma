generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Account {
  id                String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                   String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                String                @unique
  name                 String?
  passwordHash         String?
  image                String?
  emailVerified        DateTime?
  status               UserStatus            @default(ACTIVE)
  commissionPercent    Decimal               @default(0) @db.Decimal(5, 2)
  initialCommissionPercent   Decimal         @default(0) @db.Decimal(5, 2)
  recurringCommissionPercent Decimal         @default(0) @db.Decimal(5, 2)
  canProposeRates      Boolean               @default(true)
  canBeTeacher         Boolean               @default(false)
  // When false (default): rate changes re-price all EARNED+PENDING splits
  // retroactively (onboarding mode — admin iterates until numbers look right).
  // When true (locked post-onboarding): rate changes only affect future
  // commissions arriving via webhook; existing splits are frozen.
  // PENDING(rate_not_set) splits always re-price regardless — they have no
  // price to preserve. Admin toggles via PATCH /api/admin/affiliates/:id/lock.
  ratesLocked          Boolean               @default(false)
  // null = onboarding/unset; non-null = the current numeric initial and
  // recurring rates are the active configured values, including valid 0%.
  ratesConfiguredAt    DateTime?
  rewardfulAffiliateId String?               @unique
  rewardfulEmail       String?
  backfillStatus       RewardfulBackfillStatus @default(NOT_STARTED)
  backfillStartedAt    DateTime?
  backfillCompletedAt  DateTime?
  backfillError        String?
  linkError            String?
  linkInProgressAt     DateTime?
  lifetimeStatsCachedAt DateTime?
  lifetimeStatsJson    Json?
  preferredCurrency    String                @default("CAD")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt
  accounts             Account[]
  attendanceRecords    Attendance[]
  commissions          Commission[]          @relation("AffiliateCommissions") @ignore
  teacherCommissions   Commission[]          @relation("TeacherCommissions") @ignore
  affiliateEvents      CommissionEvent[]     @relation("affiliateEvents")
  recipientSplits      CommissionSplit[]     @relation("recipientSplits")
  rateChanges          CommissionRateAudit[] @relation("AffiliateRateChanges")
  rateChangesBy        CommissionRateAudit[] @relation("ChangedByUser")
  deviceTokens         DeviceToken[]
  notifications        Notification[]
  promoCodeRequests    PromoCodeRequest[]    @relation("RequesterRelation")
  promoCodeReviews     PromoCodeRequest[]    @relation("ReviewerRelation")
  proposalsMade        RateProposal[]        @relation("ProposerRelation")
  proposalsReviewed    RateProposal[]        @relation("ProposalReviewerRelation")
  proposalsFor         RateProposal[]        @relation("ProposalStudentRelation")
  sessions             Session[]
  teacherRelations     TeacherStudent[]      @relation("StudentRelation")
  studentRelations     TeacherStudent[]      @relation("TeacherRelation")

  @@index([email])
  @@index([rewardfulAffiliateId])
  @@index([status])
}

model TeacherStudent {
  id           String               @id @default(dbgenerated("(gen_random_uuid())::text"))
  teacherId    String
  studentId    String
  depth        Int                  @default(1)
  teacherCut   Decimal              @default(0) @db.Decimal(5, 2)
  status       TeacherStudentStatus @default(ACTIVE)
  createdVia   RelationshipOrigin   @default(SELF_PROPOSAL)
  reviewedAt   DateTime?
  reviewedById String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @default(now()) @updatedAt
  student      User                 @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teacher      User                 @relation("TeacherRelation", fields: [teacherId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([teacherId, studentId])
  @@index([teacherId])
  @@index([studentId])
  @@index([teacherId, status])
  @@index([status])
}

model Commission {
  id                    String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  affiliateId           String
  teacherId             String?
  rewardfulCommissionId String?
  rewardfulReferralId   String?
  idempotencyKey        String?          @unique
  currency              String           @default("USD")
  fullAmountCad         Decimal          @db.Decimal(10, 2)
  affiliateCutPercent   Decimal          @db.Decimal(5, 2)
  affiliateCutCad       Decimal          @db.Decimal(10, 2)
  teacherCutPercent     Decimal?         @db.Decimal(5, 2)
  teacherCutCad         Decimal?         @db.Decimal(10, 2)
  ceoCutCad             Decimal          @db.Decimal(10, 2)
  status                CommissionStatus @default(PENDING)
  forfeitedToCeo        Boolean          @default(false)
  forfeitureReason      String?
  conversionDate        DateTime
  paidAt                DateTime?
  voidedAt              DateTime?
  processedAt           DateTime         @default(now())
  rewardfulData         Json?
  affiliate             User             @relation("AffiliateCommissions", fields: [affiliateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  teacher               User?            @relation("TeacherCommissions", fields: [teacherId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([affiliateId])
  @@index([teacherId])
  @@index([conversionDate])
  @@index([status])
  @@index([paidAt])
  @@index([rewardfulCommissionId])
  @@ignore
}

model CommissionEvent {
  id                    String            @id @default(cuid())
  rewardfulCommissionId String?           @unique
  rewardfulReferralId   String?
  affiliateId           String
  affiliate             User              @relation("affiliateEvents", fields: [affiliateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  conversionDate        DateTime
  currency              String            @default("USD")
  fullAmount            Decimal           @map("fullAmountCad") @db.Decimal(12, 2)
  ceoCut                Decimal           @map("ceoCutCad") @db.Decimal(12, 2)
  isRecurring           Boolean           @default(false)
  upstreamState         String?
  upstreamDueAt         DateTime?
  upstreamPaidAt        DateTime?
  upstreamVoidedAt      DateTime?
  campaignId            String?
  campaignName          String?
  rewardfulData         Json?
  splits                CommissionSplit[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([affiliateId])
  @@index([conversionDate])
  @@index([rewardfulReferralId])
  @@index([upstreamState])
  @@index([upstreamDueAt])
  @@index([campaignId])
}

model CommissionSplit {
  id               String           @id @default(cuid())
  eventId          String
  event            CommissionEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recipientId      String
  recipient        User             @relation("recipientSplits", fields: [recipientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  role             CommissionRole
  depth            Int?
  cutPercent       Decimal          @db.Decimal(5, 2)
  cutAmount        Decimal          @map("cutCad") @db.Decimal(12, 2)
  status           CommissionStatus @default(PENDING)
  forfeitedToCeo   Boolean          @default(false)
  forfeitureReason String?
  paidAt           DateTime?
  voidedAt         DateTime?
  idempotencyKey   String           @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([eventId, recipientId])
  @@index([recipientId])
  @@index([status])
  @@index([paidAt])
}

model CommissionRateAudit {
  id              String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  affiliateId     String
  changedById     String
  previousPercent Decimal  @db.Decimal(5, 2)
  newPercent      Decimal  @db.Decimal(5, 2)
  field           RateField @default(LEGACY)
  // RETROACTIVE: change re-priced existing unpaid splits (onboarding mode).
  // FORWARD_ONLY: change applied only to future webhooks (locked mode).
  // LOCK / UNLOCK: the lock toggle itself — previousPercent/newPercent
  // carry 0/1 so the audit table still renders in order.
  appliedMode     RateChangeMode @default(RETROACTIVE)
  reason          String?
  createdAt       DateTime @default(now())
  affiliate       User     @relation("AffiliateRateChanges", fields: [affiliateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  changedBy       User     @relation("ChangedByUser", fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([affiliateId])
  @@index([createdAt])
}

enum RateChangeMode {
  RETROACTIVE
  FORWARD_ONLY
  LOCK
  UNLOCK
}

enum RateField {
  LEGACY
  INITIAL
  RECURRING
  LOCK
}

model RateProposal {
  id              String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  proposerId      String
  studentId       String
  proposedPercent Decimal        @db.Decimal(5, 2)
  currentPercent  Decimal        @db.Decimal(5, 2)
  status          ProposalStatus @default(PENDING)
  reviewedById    String?
  reviewNote      String?
  createdAt       DateTime       @default(now())
  reviewedAt      DateTime?
  proposer        User           @relation("ProposerRelation", fields: [proposerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewedBy      User?          @relation("ProposalReviewerRelation", fields: [reviewedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student         User           @relation("ProposalStudentRelation", fields: [studentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status])
  @@index([proposerId])
  @@index([studentId])
}

model Attendance {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId      String
  date        String
  timezone    String
  note        String?
  submittedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, date])
  @@index([userId])
  @@index([date])
}

model PromoCodeRequest {
  id                String                 @id @default(dbgenerated("(gen_random_uuid())::text"))
  requesterId       String
  reviewerId        String?
  proposedCode      String
  status            PromoCodeRequestStatus @default(PENDING_TEACHER)
  rewardfulCouponId String?
  campaignId        String?
  campaignName      String?
  rejectionReason   String?
  errorMessage      String?
  createdAt         DateTime               @default(now())
  reviewedAt        DateTime?
  requester         User                   @relation("RequesterRelation", fields: [requesterId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer          User?                  @relation("ReviewerRelation", fields: [reviewerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([requesterId])
  @@index([reviewerId])
  @@index([status])
  @@index([proposedCode])
}

model Notification {
  id        String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  sentPush  Boolean          @default(false)
  pushStatus PushStatus      @default(PENDING)
  pushError String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([type])
  @@index([pushStatus])
}

model DeviceToken {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  token     String   @unique
  deviceId  String?
  userAgent String?
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, deviceId])
  @@index([userId])
}

model ExchangeRateCache {
  id           String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(10, 6)
  fetchedAt    DateTime @default(now())

  @@unique([fromCurrency, toCurrency])
  @@index([fetchedAt])
}

enum UserStatus {
  ACTIVE
  DEACTIVATED
}

enum PromoCodeRequestStatus {
  PENDING_TEACHER
  APPROVED_TEACHER
  REJECTED_TEACHER
  CREATED
  FAILED
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommissionStatus {
  EARNED
  FORFEITED
  PENDING
  PAID
  VOIDED
}

enum CommissionRole {
  AFFILIATE
  TEACHER
}

enum RelationshipOrigin {
  SELF_PROPOSAL
  ADMIN_PAIR
}

enum NotificationType {
  CONVERSION_RECEIVED
  ATTENDANCE_FORFEITURE_ALERT
  PROMO_CODE_REQUEST_RECEIVED
  PROMO_CODE_APPROVED
  PROMO_CODE_REJECTED
  COMMISSION_RATE_CHANGED
  NEW_STUDENT_LINKED
  AFFILIATE_DEACTIVATED
  AFFILIATE_AUTO_CREATED
  RATE_PROPOSAL_SUBMITTED
  RATE_PROPOSAL_APPROVED
  RATE_PROPOSAL_REJECTED
  STUDENT_PROPOSAL_RECEIVED
  STUDENT_PROPOSAL_APPROVED
  STUDENT_PROPOSAL_REJECTED
  STUDENT_PAYMENT_RECEIVED
  COMMISSION_VOIDED
  FIRST_ATTENDANCE_RECORDED
  TEST_NOTIFICATION
}

enum PushStatus {
  PENDING
  SENT
  FAILED
  SKIPPED_NO_TOKEN
  SKIPPED_NO_MESSAGING
  SKIPPED_PREF
}

enum TeacherStudentStatus {
  PENDING
  ACTIVE
  REJECTED
  DEACTIVATED
}

enum RewardfulBackfillStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
}
